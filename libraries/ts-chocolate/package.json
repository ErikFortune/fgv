{
  "name": "@fgv/ts-chocolate",
  "version": "0.1.0",
  "description": "Chocolate recipe helpers and calculations",
  "main": "lib/index.js",
  "module": "dist/index.js",
  "types": "dist/ts-chocolate.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ts-chocolate.d.ts",
      "import": "./dist/index.js",
      "require": "./lib/index.js",
      "default": "./lib/index.js"
    }
  },
  "scripts": {
    "build": "heft build --clean",
    "build:data": "node scripts/build-ingredient-data.js",
    "clean": "heft clean",
    "test": "heft test --clean",
    "build-docs": "api-documenter markdown --input-folder ./temp --output-folder docs",
    "build-all": "rushx build && rushx build-docs",
    "coverage": "heft test --clean",
    "lint": "eslint src --ext .ts",
    "fixlint": "eslint src --ext .ts --fix",
    "data:sync": "node ../../tools/chocolate-cli/lib/cli.js sync-data --target ts-chocolate",
    "data:clean": "rm -rf data/published"
  },
  "sideEffects": false,
  "keywords": [
    "chocolate",
    "recipe",
    "ganache",
    "typescript"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fgv/ts-utils": "workspace:*",
    "@fgv/ts-json": "workspace:*",
    "@fgv/ts-json-base": "workspace:*"
  },
  "devDependencies": {
    "@fgv/ts-utils-jest": "workspace:*",
    "@fgv/heft-dual-rig": "workspace:*",
    "@microsoft/api-documenter": "^7.27.3",
    "@microsoft/api-extractor": "^7.53.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.39.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.5",
    "typescript": "5.9.3",
    "@rushstack/heft": "1.1.3",
    "@rushstack/heft-node-rig": "2.11.4",
    "@rushstack/eslint-config": "4.5.3",
    "@types/heft-jest": "1.0.6",
    "@rushstack/heft-jest-plugin": "1.1.3",
    "eslint-plugin-tsdoc": "~0.4.0",
    "yaml": "~2.8.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErikFortune/fgv.git"
  }
}
