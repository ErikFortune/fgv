{
  "name": "@fgv/ts-web-extras",
  "version": "5.1.0",
  "description": "Browser-compatible utilities and FileTree implementations",
  "main": "lib/index.js",
  "types": "dist/ts-web-extras.d.ts",
  "scripts": {
    "build": "NODE_OPTIONS=--disable-warning=DEP0040 heft test --clean",
    "clean": "heft clean",
    "test": "NODE_OPTIONS=--disable-warning=DEP0040 heft test --clean",
    "build-docs": "typedoc --options ./config/typedoc.json",
    "build-all": "rushx build; rushx build-docs",
    "test-handles": "NODE_OPTIONS=--disable-warning=DEP0040 jest --runInBand --detectOpenHandles",
    "clean-jest": "jest --clear-cache",
    "coverage": "NODE_OPTIONS=--disable-warning=DEP0040 jest --coverage",
    "lint": "eslint src --ext .ts",
    "fixlint": "eslint src --ext .ts --fix"
  },
  "sideEffects": false,
  "keywords": [
    "browser",
    "web",
    "filetree",
    "crypto",
    "typescript"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ErikFortune/fgv/issues"
  },
  "homepage": "https://github.com/ErikFortune/fgv/tree/main/libraries/ts-web-extras#readme",
  "devDependencies": {
    "@fgv/heft-dual-rig": "workspace:*",
    "@fgv/typedoc-compact-theme": "workspace:*",
    "@fgv/ts-extras": "workspace:*",
    "@fgv/ts-utils": "workspace:*",
    "@fgv/ts-json-base": "workspace:*",
    "@fgv/ts-utils-jest": "workspace:*",
    "@microsoft/api-documenter": "^7.28.2",
    "@microsoft/api-extractor": "^7.55.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "jest": "^29.7.0",
    "jest-extended": "^4.0.2",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "eslint-plugin-n": "^17.23.1",
    "@rushstack/eslint-config": "4.6.4",
    "@rushstack/heft": "1.2.7",
    "@rushstack/heft-jest-plugin": "1.2.6",
    "@rushstack/heft-node-rig": "2.11.27",
    "@types/heft-jest": "1.0.6",
    "eslint-plugin-tsdoc": "~0.5.2",
    "@rushstack/eslint-patch": "1.14.1",
    "@types/react": "~19.2.8",
    "typedoc": "~0.28.16",
    "typedoc-plugin-markdown": "~4.9.0",
    "fake-indexeddb": "~6.2.5"
  },
  "peerDependencies": {
    "@fgv/ts-extras": "workspace:*",
    "@fgv/ts-utils": "workspace:*",
    "@fgv/ts-json-base": "workspace:*",
    "react": ">=18 <20",
    "react-dom": ">=18 <20"
  },
  "exports": {
    ".": {
      "node": {
        "import": "./lib/index.js",
        "require": "./lib/index.js"
      },
      "default": {
        "import": "./lib/index.browser.js",
        "require": "./lib/index.browser.js"
      },
      "types": "dist/ts-web-extras.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ErikFortune/fgv.git"
  },
  "dependencies": {
    "idb-keyval": "^6.2.2"
  }
}
