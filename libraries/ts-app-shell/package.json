{
  "name": "@fgv/ts-app-shell",
  "version": "0.1.0",
  "description": "Shared React UI primitives for application shells: column cascade, sidebar, toast/log messages, command palette, keybinding registry",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "build": "heft build --clean",
    "clean": "heft clean",
    "test": "heft test --clean",
    "lint": "eslint src --ext .ts,.tsx",
    "fixlint": "eslint src --ext .ts,.tsx --fix",
    "coverage": "jest --coverage"
  },
  "sideEffects": false,
  "keywords": [
    "typescript",
    "react",
    "components",
    "app-shell",
    "ui"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "dependencies": {
    "@fgv/ts-utils": "workspace:*",
    "@heroicons/react": "~2.2.0",
    "tslib": "^2.8.1",
    "@fgv/ts-extras": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@fgv/heft-dual-rig": "workspace:*",
    "@fgv/ts-utils-jest": "workspace:*",
    "@types/react": "~19.2.8",
    "@types/react-dom": "~19.2.3",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "jest": "^29.7.0",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/jest-dom": "^6.4.2",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3",
    "@rushstack/heft": "1.1.7",
    "@rushstack/heft-web-rig": "1.2.0",
    "@rushstack/eslint-config": "4.6.1",
    "@rushstack/heft-jest-plugin": "1.1.7",
    "@testing-library/dom": "^10.4.0"
  },
  "exports": {
    ".": {
      "node": {
        "import": "./lib/index.js",
        "require": "./lib/index.js"
      },
      "default": {
        "import": "./lib/index.browser.js",
        "require": "./lib/index.browser.js"
      },
      "types": "lib/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErikFortune/fgv.git"
  }
}
