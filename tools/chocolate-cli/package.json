{
  "name": "@fgv/chocolate-cli",
  "version": "0.1.0",
  "description": "Command-line interface for chocolate recipe management",
  "main": "lib/index.js",
  "bin": {
    "choco": "bin/choco.js"
  },
  "scripts": {
    "build": "heft build --clean",
    "test": "heft test --clean",
    "coverage": "heft test --clean --coverage",
    "clean": "heft clean",
    "lint": "eslint src --ext .ts",
    "fixlint": "eslint src --ext .ts --fix",
    "data:publish": "node lib/cli.js publish-data --source ../../temp/data/chocolate --dest ../../data/published/chocolate",
    "data:fetch": "node lib/cli.js fetch-data --source ../../data/published/chocolate --dest ../../temp/data/chocolate",
    "data:sync": "cp -r ../../data/published/chocolate data/published",
    "data:clean": "rm -rf data/published"
  },
  "keywords": [
    "chocolate",
    "recipe",
    "cli",
    "ganache",
    "typescript"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fgv/ts-chocolate": "workspace:*",
    "@fgv/ts-utils": "workspace:*",
    "commander": "^11.0.0",
    "chalk": "^5.3.0",
    "@fgv/ts-json-base": "workspace:*",
    "yaml": "~2.8.2"
  },
  "devDependencies": {
    "@fgv/ts-utils-jest": "workspace:*",
    "@rushstack/heft": "1.1.7",
    "@rushstack/heft-node-rig": "2.11.12",
    "@rushstack/eslint-config": "4.6.1",
    "@types/heft-jest": "1.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "eslint": "^9.39.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "5.9.3",
    "@rushstack/heft-jest-plugin": "1.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ErikFortune/fgv.git"
  }
}
