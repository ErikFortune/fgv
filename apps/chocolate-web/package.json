{
  "name": "chocolate-web",
  "version": "0.1.0",
  "description": "Chocolate recipe web application",
  "private": true,
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack serve --mode development",
    "clean": "rimraf dist",
    "test": "echo 'No tests configured for chocolate-web - this is a React frontend' && exit 0",
    "data:sync": "node ../../tools/chocolate-cli/lib/cli.js sync-data --target chocolate-web",
    "data:clean": "rm -rf data/published"
  },
  "keywords": [
    "chocolate",
    "recipe",
    "ganache",
    "react",
    "typescript",
    "app"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fgv/ts-chocolate": "workspace:*",
    "@fgv/ts-utils": "workspace:*",
    "react": "~19.2.0",
    "react-dom": "~19.2.0",
    "@heroicons/react": "~2.2.0",
    "@rushstack/heft-web-rig": "1.1.5",
    "@rushstack/heft": "1.1.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "@types/react-dom": "~19.2.2",
    "@types/node": "^20.14.9",
    "typescript": "5.9.3",
    "webpack": "~5.102.1",
    "webpack-cli": "~6.0.1",
    "webpack-dev-server": "~5.2.2",
    "@babel/core": "~7.28.3",
    "@babel/preset-env": "~7.28.3",
    "@babel/preset-react": "~7.28.5",
    "@babel/preset-typescript": "~7.28.5",
    "babel-loader": "~10.0.0",
    "css-loader": "~7.1.2",
    "style-loader": "~4.0.0",
    "postcss-loader": "~8.2.0",
    "postcss": "~8.5.6",
    "autoprefixer": "~10.4.21",
    "tailwindcss": "^3.4.0",
    "html-webpack-plugin": "~5.6.4",
    "rimraf": "^6.1.0",
    "core-js": "~3.46.0",
    "whatwg-fetch": "~3.6.20",
    "stream-browserify": "~3.0.0",
    "util": "~0.12.5",
    "buffer": "~6.0.3",
    "process": "~0.11.10"
  }
}
