    "typedoc-plugin-markdown": "~4.9.0",
    "typescript": "5.9.3",
    "@types/node": "^20.14.9"
  },
  "peerDependencies": {
    "typedoc": ">=0.28.0",
    "typedoc-plugin-markdown": ">=4.0.0"
  }
