# Server
PORT=3002

# Storage backend: 'file' or 'mongo'
CHOCOLATE_LAB_STORAGE_TYPE=file

# Filesystem storage (when CHOCOLATE_LAB_STORAGE_TYPE=file)
CHOCOLATE_LAB_STORAGE_ROOT=./data/storage

# MongoDB (when CHOCOLATE_LAB_STORAGE_TYPE=mongo)
# Option 1: Full connection string (e.g. docker-compose)
MONGODB_CONNECTION_STRING=mongodb://localhost:27017
MONGODB_DB_NAME=chocolate-lab

# Option 2: Individual vars (e.g. Olares middleware injection)
# When MONGODB_CONNECTION_STRING is not set, the URI is built from these:
# MONGODB_HOST=localhost
# MONGODB_PORT=27017
# MONGODB_USER=myuser
# MONGODB_PASSWORD=mypass
# MONGODB_DATABASE=chocolate-lab    # takes precedence over MONGODB_DB_NAME

# Default user ID for storage operations (when no X-User-Id header)
MONGODB_DEFAULT_USER_ID=default-user

# Static frontend files (set in Docker container)
# STATIC_FILES_PATH=./static
