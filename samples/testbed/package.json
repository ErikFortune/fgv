{
  "name": "@fgv/testbed",
  "version": "1.0.0",
  "description": "Sample browser app + CLI showcasing fgv capabilities across scenarios. Long-lived; grows over time. See .ai/tasks/completed/2026-05/local-ai-exploration/brief.md for the cluster context.",
  "private": true,
  "main": "lib/cli.js",
  "bin": {
    "testbed": "bin/testbed.js"
  },
  "scripts": {
    "build": "heft build --clean",
    "build:web": "webpack --mode production",
    "build:data": "ts-node scripts/build-data.ts",
    "clean": "heft clean && rimraf dist-web",
    "test": "heft test --clean",
    "test-handles": "jest --runInBand --detectOpenHandles",
    "clean-jest": "jest --clear-cache",
    "update-snapshot": "jest --updateSnapshot",
    "coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "fixlint": "eslint src --ext .ts,.tsx --fix",
    "dev": "webpack serve --mode development",
    "cli": "node bin/testbed.js"
  },
  "keywords": [
    "fgv",
    "sample",
    "testbed",
    "react",
    "typescript"
  ],
  "author": "Erik Fortune",
  "license": "MIT",
  "engines": {
    "node": ">=22.22.0 <23.0.0 || >=24.15.0 <25.0.0"
  },
  "dependencies": {
    "@fgv/ts-app-shell": "workspace:*",
    "@fgv/ts-extras": "workspace:*",
    "@fgv/ts-json-base": "workspace:*",
    "@fgv/ts-utils": "workspace:*",
    "@fgv/ts-web-extras": "workspace:*",
    "react": "~19.2.3",
    "react-dom": "~19.2.3",
    "@fgv/ts-prompt-assist": "workspace:*",
    "@fgv/ts-extras-transformers": "workspace:*",
    "@fgv/ts-web-extras-transformers": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "~7.29.0",
    "@babel/preset-env": "~7.29.0",
    "@babel/preset-react": "~7.28.5",
    "@babel/preset-typescript": "~7.28.5",
    "@fgv/heft-dual-rig": "workspace:*",
    "@fgv/ts-utils-jest": "workspace:*",
    "@rushstack/eslint-config": "4.6.4",
    "@rushstack/heft": "1.2.7",
    "@rushstack/heft-jest-plugin": "1.2.6",
    "@rushstack/heft-node-rig": "2.11.27",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^16",
    "@types/heft-jest": "1.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.9",
    "@types/react": "~19.2.8",
    "@types/react-dom": "~19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "autoprefixer": "~10.4.23",
    "babel-loader": "~10.1.0",
    "css-loader": "~7.1.2",
    "eslint": "^9.39.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^17.23.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-tsdoc": "~0.5.2",
    "html-webpack-plugin": "~5.6.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "~8.5.6",
    "postcss-loader": "~8.2.0",
    "rimraf": "^6.1.2",
    "style-loader": "~4.0.0",
    "tailwindcss": "^3.4.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "webpack": "~5.105.4",
    "webpack-cli": "~6.0.1",
    "webpack-dev-server": "~5.2.2"
  }
}
